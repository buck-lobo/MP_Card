{
  "name": "telegram-bot-functions",
  "description": "Telegram bot via webhook on Firebase Cloud Functions with Firestore.",
  "version": "1.0.6",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && node ../scripts/check-functions-lib.cjs",
    "lint": "echo \"no lint configured\"",
    "deploy": "firebase deploy --only functions",
    "serve": "firebase emulators:start --only functions"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@tma.js/init-data-node": "^2.0.4",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/node": "^18.17.0",
    "typescript": "^5.5.0"
  },
  "private": true
}
